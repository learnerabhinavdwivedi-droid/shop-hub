{
    "manifest_version": 3,
    "name": "Shop Hub Universal Price Tracker",
    "version": "1.1",
    "description": "Track prices across any shopping website instantly.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "<all_urls>",
        "http://localhost:5000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}